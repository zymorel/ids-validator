    <!-- ══ SP-09 : Revêtements ═════════════════════════════ -->
    <ids:specification ifcVersion="IFC4X3_ADD2"
                       name="Uniformat — Revêtements (IfcCovering)"
                       identifier="SP-09"
                       description="Chaque revêtement doit avoir une classification Uniformat."
