<?xml version="1.0" encoding="UTF-8"?>
<ids:ids xmlns:xs="http://www.w3.org/2001/XMLSchema"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://standards.buildingsmart.org/IDS http://standards.buildingsmart.org/IDS/1.0/ids.xsd"
         xmlns:ids="http://standards.buildingsmart.org/IDS">

  <ids:info>
    <ids:title>Exigence Classification Uniformat</ids:title>
    <ids:version>1.0</ids:version>
    <ids:description>Tous les éléments physiques du modèle doivent avoir une classification Uniformat. ifctester ne reconnaissant pas les classes abstraites (IfcElement), chaque type concret est ciblé individuellement.</ids:description>
    <ids:author>formation@ids.com</ids:author>
    <ids:date>2026-03-07</ids:date>
    <ids:purpose>Vérification de la classification Uniformat sur tous les éléments</ids:purpose>
  </ids:info>

  <ids:specifications>

    <!-- ══ SP-01 : Murs ════════════════════════════════════ -->
    <ids:specification ifcVersion="IFC4X3_ADD2"
                       name="Uniformat — Murs (IfcWall)"
                       identifier="SP-01"
                       description="Chaque mur doit avoir une classification Uniformat."
                       instructions="Appliquer un Assembly Code Uniformat à chaque mur dans Revit.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name><ids:simpleValue>IFCWALL</ids:simpleValue></ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:classification cardinality="required" instructions="Code Uniformat requis. Ex: B2010 (mur ext.), C1010 (cloison).">
          <ids:system><ids:simpleValue>Uniformat</ids:simpleValue></ids:system>
        </ids:classification>
      </ids:requirements>
    </ids:specification>

    <!-- ══ SP-02 : Dalles ══════════════════════════════════ -->
    <ids:specification ifcVersion="IFC4X3_ADD2"
                       name="Uniformat — Dalles (IfcSlab)"
                       identifier="SP-02"
                       description="Chaque dalle doit avoir une classification Uniformat."
                       instructions="Appliquer un Assembly Code Uniformat à chaque dalle dans Revit.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name><ids:simpleValue>IFCSLAB</ids:simpleValue></ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:classification cardinality="required" instructions="Code Uniformat requis. Ex: B1010 (plancher), A1030 (dallage).">
          <ids:system><ids:simpleValue>Uniformat</ids:simpleValue></ids:system>
        </ids:classification>
      </ids:requirements>
    </ids:specification>

    <!-- ══ SP-03 : Portes ══════════════════════════════════ -->
