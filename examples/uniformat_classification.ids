        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:classification cardinality="required" instructions="Code Uniformat requis. Ex: B2020 (fenêtre ext.), C1030 (fenêtre int.).">
          <ids:system><ids:simpleValue>Uniformat</ids:simpleValue></ids:system>
        </ids:classification>
      </ids:requirements>
    </ids:specification>

