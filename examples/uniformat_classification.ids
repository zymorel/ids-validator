      </ids:applicability>
      <ids:requirements>
        <ids:classification cardinality="required" instructions="Code Uniformat requis. Ex: B3010 (toiture terrasse), B3020 (toiture en pente).">
          <ids:system><ids:simpleValue>Uniformat</ids:simpleValue></ids:system>
        </ids:classification>
      </ids:requirements>
